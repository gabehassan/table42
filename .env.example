# Resy Auth (email+password login → auth_token)
RESY_EMAIL=
RESY_PASSWORD=

# Target reservation
RESY_VENUE_ID=25973
RESY_DATE=2026-03-23
RESY_TIME=19:00
RESY_PARTY_SIZE=2
RESY_TABLE_TYPE=Indoor Dining

# Payment (required for booking — get from browser DevTools)
RESY_PAYMENT_ID=

# Time range — accept any slot in this window, sorted by proximity to RESY_TIME
RESY_TIME_RANGE=17:00-22:00

# Sniper tuning
RESY_SHOTS=3
RESY_MAX_BOOK=5
RESY_DROP_TIME=

# Monitor mode
RESY_MONITOR=false
RESY_MONITOR_INTERVAL=30
RESY_PROXY_FILE=

# Captcha (optional — only needed if venue requires reCAPTCHA at drop time)
# CAPSolver: capsolver.com ($0.80/1K, AI-based, 5-15s avg)
RESY_CAPSOLVER_KEY=

# Notifications (Discord or Slack webhook URL)
RESY_WEBHOOK=

# Output
RESY_OUTPUT=
